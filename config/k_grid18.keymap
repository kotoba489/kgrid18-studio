#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    combos {
        compatible = "zmk,combos";

        BS {
            bindings = <&kp BACKSPACE>;
            key-positions = <34 33>;
        };

        kanaE {
            bindings = <&kp LC(SPACE)>;
            key-positions = <32 31>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
&kp D  &kp D    &kp E           &kp U      &kp COMMA  &kp H      &kp S      &kp Y     &kp R  &kp B
&kp Z  &kp J    &kp I           &kp A      &kp O      &kp K      &kp N      &kp T     &kp W  &kp P
&mo 1  &lt 2 X  &kp C           &kp V      &kp DOT    &kp G      &kp M      &kp F     &kp L  &kp MINUS
                &kp LEFT_SHIFT  &kp LA(D)  &kp LGUI   &kp SPACE  &kp ENTER  &kp RALT
            >;
        };

        layer_1 {
            display-name = "Edit";
            bindings = <
&kp LS(LEFT_BRACKET)  &kp LS(RIGHT_BRACKET)  &kp LBKT        &kp RBKT     &kp ESC    &kp TAB    &kp N7     &kp N8  &kp N9  &kp N0
&none                 &none                  &kp LPAR        &kp RPAR     &kp SLASH  &kp EQUAL  &kp N4     &kp N5  &kp N6  &kp AT
&none                 &none                  &none           &kp PERCENT  &kp DOT    &kp MINUS  &kp N1     &kp N2  &kp N3  &none
                                             &kp LEFT_SHIFT  &kp LC(D)    &kp LGUI   &kp SPACE  &kp ENTER  &kp D
            >;
        };

        layer_2 {
            bindings = <
&none  &bt BT_CLR_ALL  &none         &none         &none         &none           &none  &none           &none           &none
&none  &bt BT_SEL 0    &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &msc SCRL_UP    &none  &mkp RCLK       &mmv MOVE_UP    &mkp LCLK
&none  &none           &none         &none         &none         &msc SCRL_DOWN  &none  &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_RIGHT
                       &none         &none         &none         &none           &none  &none
            >;
        };
    };
};
